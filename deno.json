{
  "workspace": ["./infrastructure/platforms/deno"],
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env infrastructure/platforms/deno/main.ts",
    "start:api": "deno run --allow-net --allow-env --allow-read infrastructure/platforms/deno/main.ts",
    "start:front": "npm run dev --prefix infrastructure/client/next",
    "start:all": "deno task start:api & deno task start:front",
    "generate:prisma": "cd infrastructure/database/prisma && deno run -A npm:prisma@latest generate --no-engine",
    "seed": "deno run --allow-net --allow-env --allow-read infrastructure/database/prisma/seed.ts",
    "lint": "deno lint",
    "format:fix": "deno fmt"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "lineWidth": 120
  },
  "imports": {
    "bcryptjs": "npm:bcryptjs@^2.4.3",
    "i18n-iso-countries": "npm:i18n-iso-countries@^7.13.0",
    "libphonenumber-js": "npm:libphonenumber-js@^1.11.17",
    "jsonwebtoken": "npm:jsonwebtoken@9.0.2",
    "dotenv": "https://deno.land/std@0.203.0/dotenv/mod.ts"
  },
  "exclude": [
    "node_modules",
    ".next"
  ]
}
