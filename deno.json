{
  "workspace": ["./infrastructure/platforms/deno"],
  "tasks": {
    "dev": "deno run --watch --allow-net infrastructure/platforms/deno/index.ts",
    "start": "deno run --allow-net infrastructure/platforms/deno/index.ts",
    "lint": "deno lint",
    "format:fix": "deno fmt"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "lineWidth": 120
  },
  "imports": {
    "prisma": "https://deno.land/x/prisma@2.30.0/mod.ts",
    "bcryptjs": "npm:bcryptjs@^2.4.3",
    "i18n-iso-countries": "npm:i18n-iso-countries@^7.13.0",
    "libphonenumber-js": "npm:libphonenumber-js@^1.11.17"
  },
  "exclude": [
    "interface",
    "node_modules",
    ".next"
  ]
}
