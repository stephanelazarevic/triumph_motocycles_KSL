generator client_deno {
  provider        = "prisma-client-js"
  previewFeatures = ["deno"]
  output          = "./generated/client-deno"
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id      String             @id @default(uuid())
  idUser  String
  type    NotificationType
  message String
  date    DateTime
  user    User               @relation(fields: [idUser], references: [id])
  status  NotificationStatus

  createdAt DateTime @default(now())

  @@map("notifications")
}

enum NotificationType {
  info
  alerte
  erreur
}

enum NotificationStatus {
  read
  unread
}

model User {
  id              String  @id @default(uuid())
  firstname       String
  lastname        String
  hashedPassword  String
  emailAddress    String  @unique
  phoneNumber     Json?
  address         Json
  isAdministrator Boolean
  token           String?

  dealer        Dealer?
  enterprise    Enterprise?
  client        Client?
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Dealer {
  id         String       @id @default(uuid())
  site       String
  user       User         @relation(fields: [id], references: [id])
  clients    Client[]
  motorcycle Motorcycle[] @relation("DealerMotorcycle")
  part       Part[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dealers")
}

model Enterprise {
  id           String       @id @default(uuid())
  taxNumber    String
  industryType IndustryType
  user         User         @relation(fields: [id], references: [id])
  drivers      Driver[]
  motorcycle   Motorcycle[] @relation("EnterpriseMotorcycle")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("enterprises")
}

enum IndustryType {
  restaurant
  coursier
  divertissement
}

model Client {
  id         String       @id @default(uuid())
  idDealer   String
  dealer     Dealer       @relation(fields: [idDealer], references: [id])
  user       User         @relation(fields: [id], references: [id])
  rentals    Rental[]
  testRides  TestRide[]
  motorcycle Motorcycle[] @relation("ClientMotorcycle")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model TestRide {
  id           String     @id @default(uuid())
  idClient     String
  idMotorcycle String
  date         DateTime
  feedback     String?
  isCompleted  Boolean
  client       Client     @relation(fields: [idClient], references: [id])
  motorcycle   Motorcycle @relation(fields: [idMotorcycle], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("test_rides")
}

model Rental {
  id           String     @id @default(uuid())
  idClient     String
  idMotorcycle String
  startDate    DateTime
  endDate      DateTime
  cost         Float
  isCompleted  Boolean
  client       Client     @relation(fields: [idClient], references: [id])
  motorcycle   Motorcycle @relation(fields: [idMotorcycle], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rentals")
}

model Motorcycle {
  id                 String           @id @default(uuid())
  clientId           String?
  dealerId           String
  enterpriseId       String?
  brand              String
  model              String
  year               Int
  registrationNumber String           @unique
  status             MotorcycleStatus
  client             Client?          @relation(fields: [clientId], references: [id], name: "ClientMotorcycle")
  dealer             Dealer           @relation(fields: [dealerId], references: [id], name: "DealerMotorcycle")
  enterprise         Enterprise?      @relation(fields: [enterpriseId], references: [id], name: "EnterpriseMotorcycle")
  testRides          TestRide[]
  rentals            Rental[]
  maintenance        Maintenance[]
  breakdowns         Incident[]
  warranties         Warranty[]
  parts              MotorcyclePart[]
  drivers            Driver[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("motorcycles")
}

enum MotorcycleStatus {
  available
  rented
  in_maintenance
}

model MotorcyclePart {
  idMotorcycle String
  idPart       String
  motorcycle   Motorcycle @relation(fields: [idMotorcycle], references: [id])
  part         Part       @relation(fields: [idPart], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([idMotorcycle, idPart])
  @@map("motorcycle_parts")
}

model Part {
  id             String           @id @default(uuid())
  idDealer       String
  idOrder        String?
  reference      String
  type           String
  price          Float
  stockQuantity  Int
  order          Order?           @relation(fields: [idOrder], references: [id])
  dealer         Dealer           @relation(fields: [idDealer], references: [id])
  warranties     WarrantyParts[]
  motorcyclePart MotorcyclePart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("parts")
}

model Order {
  id          String      @id @default(uuid())
  parts       Json
  orderDate   DateTime
  status      OrderStatus
  totalAmount Float
  Part        Part[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

enum OrderStatus {
  awaiting
  confirmed
  canceled
}

model WarrantyParts {
  idPart        String
  idWarranty    String
  actionDate    DateTime
  actionType    ActionType
  status        WarrantyStatus
  coveredCost   Float
  remainingCost Float
  part          Part           @relation(fields: [idPart], references: [id])
  warranty      Warranty       @relation(fields: [idWarranty], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([idPart, idWarranty])
  @@map("warranty_parts")
}

enum ActionType {
  repaired
  replaced
}

enum WarrantyStatus {
  in_progress
  done
  canceled
}

model Warranty {
  id            String          @id @default(uuid())
  idMotorcycle  String
  type          String
  startDate     DateTime
  endDate       DateTime
  terms         String?
  motorcycle    Motorcycle      @relation(fields: [idMotorcycle], references: [id])
  warrantyParts WarrantyParts[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("warranties")
}

model Maintenance {
  id           String     @id @default(uuid())
  idMotorcycle String
  date         DateTime
  description  String
  cost         Float
  motorcycle   Motorcycle @relation(fields: [idMotorcycle], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("maintenancies")
}

model Incident {
  id             String         @id @default(uuid())
  idMotorcycle   String
  type           IncidentType
  description    String
  reportDate     DateTime
  resolutionDate DateTime?
  status         IncidentStatus
  motorcycle     Motorcycle     @relation(fields: [idMotorcycle], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("incidents")
}

enum IncidentType {
  panne
  accident
}

enum IncidentStatus {
  pending
  resolved
  in_progress
}

model Driver {
  id            String     @id @default(uuid())
  enterpriseId  String
  motorcycleId  String
  firstname     String
  lastname      String
  licenseNumber String
  phoneNumber   Json
  emailAddress  String     @unique
  entreprise    Enterprise @relation(fields: [enterpriseId], references: [id])
  motorcycle    Motorcycle @relation(fields: [motorcycleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("drivers")
}
