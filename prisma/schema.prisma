generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"  
  url      = env("DATABASE_URL")
}

model Notif {
  id        Int      @id @default(autoincrement())
  idUser    Int
  type      NotifType
  message   String
  date      DateTime
  status    NotifStatus
  user      User     @relation(fields: [idUser], references: [id])
}

enum NotifType {
  info
  alerte
  erreur
}

enum NotifStatus {
  read
  unread
}

model User {
  id            Int          @id @default(autoincrement())
  name          String
  role          UserRole
  email         String       @unique
  hashedPassword String
  phone         String?
  address       String?
  dealer        Dealer?
  enterprise    Enterprise?
  client        Client?
  notifications Notif[]
}

enum UserRole {
  user
  admin
}

model Dealer {
  id        Int      @id
  location  String
  user      User     @relation(fields: [id], references: [id])
  clients   Client[]
  motos     Moto[]   @relation("DealerMotos")  // Relation avec les motos
}

model Enterprise {
  id           Int       @id
  taxNumber    String
  industryType IndustryType
  user         User      @relation(fields: [id], references: [id])
  drivers      Driver[]
}

enum IndustryType {
  restaurant
  coursier
  divertissement
}

model Client {
  id        Int      @id
  idDealer  Int
  dealer    Dealer   @relation(fields: [idDealer], references: [id])
  user      User     @relation(fields: [id], references: [id])
  rentals   Rental[]
  testRides TestRide[]
  motos     Moto[]   @relation("ClientMotos")  // Relation avec les motos
}

model TestRide {
  id        Int      @id @default(autoincrement())
  idClient  Int
  idMoto    Int
  date      DateTime
  feedback  String?
  isCompleted Boolean
  client    Client   @relation(fields: [idClient], references: [id])
  moto      Moto     @relation(fields: [idMoto], references: [id])
}

model Rental {
  id        Int      @id @default(autoincrement())
  idClient  Int
  idMoto    Int
  startDate DateTime
  endDate   DateTime
  cost      Float
  isCompleted Boolean
  client    Client   @relation(fields: [idClient], references: [id])
  moto      Moto     @relation(fields: [idMoto], references: [id])
}

model Moto {
  id              Int      @id @default(autoincrement())
  idClient        Int?
  idDealer        Int
  model           String
  registrationNumber String @unique
  status          MotoStatus
  client          Client?  @relation(fields: [idClient], references: [id], name: "ClientMotos")
  dealer          Dealer   @relation(fields: [idDealer], references: [id], name: "DealerMotos")
  testRides       TestRide[]
  rentals         Rental[]
  maintenance     Maintenance[]
  breakdowns      Breakdown[]
  warranties      Warranty[]
  parts           MotoPart[]
  driver          Driver[]  // Relation avec Driver
}

enum MotoStatus {
  available
  rented
  in_maintenance
}

model MotoPart {
  idMoto  Int
  idPart  Int
  moto    Moto     @relation(fields: [idMoto], references: [id])
  part    Part     @relation(fields: [idPart], references: [id])
  @@id([idMoto, idPart])
}

model Part {
  id          Int      @id @default(autoincrement())
  idCommand   Int
  reference   String
  type        String
  price       Float
  stockQuantity Int
  command     Command  @relation(fields: [idCommand], references: [id])
  warranties  WarrantyParts[]

  MotoPart MotoPart[]
}

model Command {
  id          Int      @id @default(autoincrement())
  parts       Json
  orderDate   DateTime
  status      CommandStatus
  totalAmount Float
  Part        Part[]
}

enum CommandStatus {
  awaiting
  confirmed
  canceled
}

model WarrantyParts {
  idPart       Int
  idWarranty   Int
  actionDate   DateTime
  actionType   ActionType
  status       WarrantyStatus
  coveredCost  Float
  remainingCost Float
  part         Part     @relation(fields: [idPart], references: [id])
  warranty     Warranty @relation(fields: [idWarranty], references: [id])
  @@id([idPart, idWarranty])
}

enum ActionType {
  repaired
  replaced
}

enum WarrantyStatus {
  in_progress
  done
  canceled
}

model Warranty {
  id            Int      @id @default(autoincrement())
  idMoto        Int
  warrantyType  String
  startDate     DateTime
  endDate       DateTime
  terms         String?
  moto          Moto     @relation(fields: [idMoto], references: [id])
  warrantyParts WarrantyParts[]
}

model Maintenance {
  id        Int      @id @default(autoincrement())
  idMoto    Int
  date      DateTime
  description String
  cost      Float
  moto      Moto     @relation(fields: [idMoto], references: [id])
}

model Breakdown {
  id             Int      @id @default(autoincrement())
  idMoto         Intk
  type           BreakdownType
  description    String
  reportDate     DateTime
  resolutionDate DateTime?
  status         BreakdownStatus
  moto           Moto     @relation(fields: [idMoto], references: [id])
}

enum BreakdownType {
  panne
  accident
}

enum BreakdownStatus {
  pending
  resolved
  in_progress
}

model Driver {
  id            Int      @id @default(autoincrement())
  idEntreprise  Int
  idMoto        Int
  firstname     String
  lastname      String
  licenseNumber String
  phone         String?
  email         String  @unique
  entreprise    Enterprise @relation(fields: [idEntreprise], references: [id])
  moto          Moto     @relation(fields: [idMoto], references: [id])
}
